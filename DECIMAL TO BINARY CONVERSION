import java.util.*;
public class Revision {
    public static void main(String args[]) {
       int pow = 0;
       int binnum = 0;
       int n = 7;

       while(n>0){
        int rem = n%2;
        binnum = binnum + (rem * (int)Math.pow(10,pow));
        pow++;
        n=n/2;

       }
       System.out.print(binnum);
    }
